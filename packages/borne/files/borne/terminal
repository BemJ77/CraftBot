-- Démarrage
------------------------------------------------------------

local function main()
    local initialized, initError = gui.init(0.5)

    if not initialized then
        logger.error(initError)
        return
    end

    local opened, openResult = network.open()

    if not opened then
        gui.status(
            "Erreur",
            tostring(openResult),
            colors.red
        )

        logger.error(openResult)
        return
    end

    local discovered, discoveryError =
        discoverServer()

    if not discovered then
        gui.messageBox(
            "Connexion impossible",
            discoveryError,
            false,
            "FERMER"
        )

        logger.error(discoveryError)
        return
    end

    local loaded, recipesError =
        requestRecipes()

    if not loaded then
        gui.messageBox(
            "Recettes indisponibles",
            tostring(recipesError),
            false,
            "FERMER"
        )

        logger.error(recipesError)
        return
    end

    buildCategories()

    if #state.categories == 0 then
        gui.messageBox(
            "Aucune recette",
            "Aucune recette visible n'a ete recue.",
            false,
            "FERMER"
        )

        return
    end

    parallel.waitForAny(
        browseRecipes,
        heartbeatLoop
    )
end

local ok, errorMessage = pcall(main)

if not ok then
    logger.error(errorMessage)

    local displayed = pcall(function()
        gui.messageBox(
            "Erreur critique",
            tostring(errorMessage),
            false,
            "FERMER"
        )
    end)

    if not displayed then
        printError(errorMessage)
    end
end
