local function drawPagedList(
    title,
    subtitle,
    items,
    labelFunction,
    page,
    showBack
)
    gui.clear(gui.theme.background)
    gui.topBar(
        "CraftBot",
        subtitle or title,
        getKitchenStatusText(),
        gui.theme.success
    )

    local width, height = gui.getSize()
    local firstY = 5
    local buttonHeight = 3
    local gap = 1

    -- Réserve de la place pour la navigation et le panier.
    local footerHeight = 8
    local usableHeight =
        height - firstY - footerHeight + 1

    local perPage = math.max(
        1,
        math.floor(
            (usableHeight + gap)
                / (buttonHeight + gap)
        )
    )

    local pageCount =
        math.max(1, math.ceil(#items / perPage))

    page = math.max(
        1,
        math.min(page or 1, pageCount)
    )

    local startIndex =
        (page - 1) * perPage + 1

    local endIndex =
        math.min(
            #items,
            startIndex + perPage - 1
        )

    local y = firstY

    for index = startIndex, endIndex do
        local item = items[index]

        gui.button(
            "item",
            2,
            y,
            width - 2,
            buttonHeight,
            labelFunction(item),
            {
                backgroundColor = gui.theme.surface,
                data = item,
                align = "left",
                leftMarker = true,
                markerColor = gui.theme.accent
            }
        )

        y = y + buttonHeight + gap
    end

    local navigationY = height - 7
    local sideWidth =
        math.max(7, math.floor((width - 6) / 4))

    gui.button(
        "previous",
        2,
        navigationY,
        sideWidth,
        2,
        "< PREV",
        {
            enabled = page > 1,
            backgroundColor = gui.theme.primary
        }
    )

    gui.drawPageIndicator(
        page,
        pageCount,
        navigationY
    )

    gui.button(
        "next",
        width - sideWidth,
        navigationY,
        sideWidth,
        2,
        "SUIV >",
        {
            enabled = page < pageCount,
            backgroundColor = gui.theme.primary
        }
    )

    if showBack then
        local backWidth =
            math.max(9, math.floor(width / 3))

        gui.button(
            "back",
            2,
            height - 4,
            backWidth,
            3,
            "RETOUR",
            {
                backgroundColor = colors.red
            }
        )
    end

    drawCartButton()

    return page, pageCount
end

local function selectCategory()
    local page = 1

    while true do
        page = drawPagedList(
            "Categories",
            "Choisissez une categorie",
            state.categories,
            function(category)
                return category.name
                    .. "  ["
                    .. tostring(#category.recipes)
                    .. "]"
            end,
            page,
            false
        )

        local action, category = gui.waitTouch()

        if action == "item" then
            state.selectedCategory = category
            return "category"
        elseif action == "cart" then
            return "cart"
        elseif action == "previous" then
            page = page - 1
        elseif action == "next" then
            page = page + 1
        end
    end
end

local function selectRecipe()
    local page = 1

    while true do
        page = drawPagedList(
            state.selectedCategory.name,
            state.selectedCategory.name,
            state.selectedCategory.recipes,
            function(recipe)
                return tostring(recipe.label or recipe.id)
            end,
            page,
            true
        )

        local action, recipe = gui.waitTouch()

        if action == "item" then
            state.selectedRecipe = recipe
            state.quantity = 1
            return "recipe"
        elseif action == "back" then
            return "back"
        elseif action == "cart" then
            return "cart"
        elseif action == "previous" then
            page = page - 1
        elseif action == "next" then
            page = page + 1
        end
    end
end

