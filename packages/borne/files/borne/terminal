------------------------------------------------------------
-- Réseau
------------------------------------------------------------

local function waitForMessage(timeoutSeconds, predicate)
    local timer = os.startTimer(timeoutSeconds)

    while true do
        local event, p1, p2, p3 = os.pullEvent()

        if event == "timer" and p1 == timer then
            return nil, nil, "Delai d'attente depasse"
        end

        if event == "rednet_message" then
            local senderId = p1
            local message = p2
            local receivedProtocol = p3

            if receivedProtocol == protocol.NAME
                and type(message) == "table"
                and predicate(senderId, message) then

                return senderId, message
            end
        end
    end
end

local function borneName()
    return os.getComputerLabel() or ("Borne " .. tostring(os.getComputerID()))
end

local function discoverServer()
    gui.status("CraftBot", "Recherche du serveur...", colors.yellow,
        "Connexion au restaurant")

    network.broadcast(protocol.makeMessage(protocol.TYPE.SERVER_DISCOVER, {
        role = protocol.ROLE.TERMINAL,
        id = os.getComputerID(),
        name = borneName()
    }))

    local senderId, message, receiveError = waitForMessage(
        DISCOVERY_TIMEOUT,
        function(_, receivedMessage)
            return receivedMessage.type == protocol.TYPE.SERVER_ANNOUNCE
        end
    )

    if not message then return false, receiveError or "Serveur introuvable" end

    local data = message.data or message
    state.serverId = tonumber(data.id) or senderId
    state.serverName = data.name or ("Serveur " .. tostring(state.serverId))

    network.send(state.serverId, protocol.makeMessage(
        protocol.TYPE.CLIENT_REGISTER, {
            role = protocol.ROLE.TERMINAL,
            id = os.getComputerID(),
            name = borneName(),
            clientVersion = BORNE_VERSION
        }
    ))

    local _, registration, registrationError = waitForMessage(
        DISCOVERY_TIMEOUT,
        function(id, receivedMessage)
            return id == state.serverId
                and receivedMessage.type == protocol.TYPE.CLIENT_REGISTERED
        end
    )

    if not registration then return false, registrationError end
    local registrationData = registration.data or registration
    if not registrationData.accepted then
        return false, registrationData.reason or "Inscription refusee"
    end

    state.registered = true
    gui.status("CraftBot", "Serveur connecte", colors.lime, state.serverName)
    sleep(1)
    return true
end

local function requestRecipes()
    gui.status("CraftBot", "Chargement des recettes...", colors.yellow,
        state.serverName or "Serveur")

    local sent, sendError = network.send(state.serverId, {
        type = protocol.TYPE.RECIPES_REQUEST
    })
    if not sent then return false, sendError end

    local _, message, receiveError = waitForMessage(
        RECIPES_TIMEOUT,
        function(senderId, receivedMessage)
            return senderId == state.serverId
                and receivedMessage.type == protocol.TYPE.RECIPES_RESPONSE
        end
    )
    if not message then return false, receiveError end
    if message.success == false then
        return false, message.error or "Recettes refusees par le serveur"
    end
    if type(message.recipes) ~= "table" then
        return false, "Liste des recettes invalide"
    end
    state.recipes = message.recipes
    return true
end

------------------------------------------------------------
-- Recettes et catégories
------------------------------------------------------------

local function buildCategories()
    local grouped = {}

    for _, recipe in ipairs(state.recipes) do
        if type(recipe) == "table" and recipe.id then
            local categoryName =
                tostring(recipe.category or "Autres")

            if not grouped[categoryName] then
                grouped[categoryName] = {}
            end

            grouped[categoryName][#grouped[categoryName] + 1] =
                recipe
        end
    end

    state.categories = {}

    for categoryName, recipes in pairs(grouped) do
        table.sort(recipes, function(a, b)
            return string.lower(tostring(a.label or a.id))
                < string.lower(tostring(b.label or b.id))
        end)

        state.categories[#state.categories + 1] = {
            name = categoryName,
            recipes = recipes
        }
    end

    table.sort(state.categories, function(a, b)
        return string.lower(a.name) < string.lower(b.name)
    end)
end

------------------------------------------------------------
-- Panier
------------------------------------------------------------

local function getCartArticleCount()
    local count = 0

    for _, item in ipairs(state.cart) do
        count = count + item.quantity
    end

    return count
end

local function getCartLineCount()
    return #state.cart
end

local function addToCart(recipe, quantity)
    for _, item in ipairs(state.cart) do
        if item.recipe.id == recipe.id then
            item.quantity = item.quantity + quantity
            return
        end
    end

    state.cart[#state.cart + 1] = {
        recipe = recipe,
        quantity = quantity
    }
end

local function removeFromCart(itemToRemove)
    for index, item in ipairs(state.cart) do
        if item == itemToRemove then
            table.remove(state.cart, index)
            return
        end
    end
end

local function drawCartButton()
    local width, height = gui.getSize()
    local count = getCartArticleCount()
    local label = "PANIER [" .. tostring(count) .. "]"
    local buttonWidth = math.min(14, math.max(10, #label + 2))

    gui.button(
        "cart",
        width - buttonWidth + 1,
        height - 4,
        buttonWidth,
        3,
        label,
        {
            backgroundColor = gui.theme.accent,
            textColor = colors.black
        }
    )
end

local function getKitchenStatusText()
    if state.registered then
        return "SERVEUR CONNECTE"
    end

    return "SERVEUR HORS LIGNE"
end

