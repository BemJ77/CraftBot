local function openCart()
    local page = 1

    while true do
        page = drawCartScreen(page)

        local action, item = gui.waitTouch()

        if action == "remove" then
            removeFromCart(item)

            local lineCount = getCartLineCount()

            if lineCount == 0 then
                page = 1
            end
        elseif action == "previous" then
            page = page - 1
        elseif action == "next" then
            page = page + 1
        elseif action == "back" then
            return "back"
        elseif action == "order" then
            return "order"
        end
    end
end

local function generateOrderNumber()
    local computerId = os.getComputerID()
    local suffix

    local ok, epoch = pcall(function()
        return os.epoch("utc")
    end)

    if ok and epoch then
        suffix = tostring(epoch):sub(-6)
    else
        suffix =
            tostring(os.day())
            .. string.format("%04d", math.floor(os.time() * 100))
    end

    return "CB-" .. tostring(computerId) .. "-" .. suffix
end


------------------------------------------------------------
-- Impression du ticket
------------------------------------------------------------

local function findPrinter()
    return peripheral.find("printer")
end

local function getRecipeLabel(recipe)
    return tostring(recipe.label or recipe.id or "Article")
end

local function printOrderTicket(orderNumber)
    local printer = findPrinter()

    if not printer then
        return false, "Aucune imprimante detectee"
    end

    if printer.getPaperLevel and printer.getPaperLevel() <= 0 then
        return false, "L'imprimante n'a plus de papier"
    end

    if printer.getInkLevel and printer.getInkLevel() <= 0 then
        return false, "L'imprimante n'a plus d'encre"
    end

    if not printer.newPage() then
        return false, "Impossible de preparer une nouvelle page"
    end

    printer.setPageTitle("Ticket " .. orderNumber)
    printer.setCursorPos(1, 1)
    printer.write("CRAFTBOT RESTAURANT")
    printer.setCursorPos(1, 2)
    printer.write("Commande " .. orderNumber)
    printer.setCursorPos(1, 3)
    printer.write(string.rep("-", 20))

    local line = 4
    local totalArticles = 0

    for _, item in ipairs(state.cart) do
        local quantity = tonumber(item.quantity) or 0
        totalArticles = totalArticles + quantity

        local text = tostring(quantity) .. " x " .. getRecipeLabel(item.recipe)

        while #text > 25 do
            printer.setCursorPos(1, line)
            printer.write(text:sub(1, 25))
            text = text:sub(26)
            line = line + 1
        end

        printer.setCursorPos(1, line)
        printer.write(text)
        line = line + 1
    end

    line = line + 1
    printer.setCursorPos(1, line)
    printer.write(string.rep("-", 20))
    printer.setCursorPos(1, line + 1)
    printer.write("Total : " .. tostring(totalArticles) .. " article(s)")
    printer.setCursorPos(1, line + 3)
    printer.write("Merci et bon appetit !")

    if not printer.endPage() then
        return false, "L'impression du ticket a echoue"
    end

    return true
end

local function askForTicket(orderNumber)
    local printerAvailable = findPrinter() ~= nil

    if not printerAvailable then
        gui.messageBox(
            "Ticket indisponible",
            "Aucune imprimante n'est detectee. La commande va continuer sans ticket.",
            false,
            "CONTINUER"
        )
        gui.waitTouch()
        return true
    end

    gui.confirmBox(
        "Ticket de commande",
        "Voulez-vous imprimer un ticket pour la commande " .. orderNumber .. " ?",
        "OUI",
        "NON",
        true
    )

    local action = gui.waitTouch()

    if action ~= "yes" then
        return true
    end

    local printed, printError = printOrderTicket(orderNumber)

    if not printed then
        gui.messageBox(
            "Impression impossible",
            tostring(printError) .. ". La commande peut tout de meme continuer.",
            false,
            "CONTINUER"
        )
        gui.waitTouch()
    end

    return true
end

------------------------------------------------------------
-- Fabrication parallèle de la commande
------------------------------------------------------------

local function finalCraftTasks(tasks)
    local grouped = {}
    local ordered = {}
    local intermediateStarted = false
    local intermediateFailed = false

    -- Les sous-crafts restent masqués, mais leur état influence
    -- désormais l'état graphique du produit final.
    for _, task in ipairs(tasks or {}) do
        local phase = tonumber(task.phase) or 0

        if phase > 0 then
            if task.status == "running"
                or task.status == "ready" then
                intermediateStarted = true
            elseif task.status == "failed" then
                intermediateFailed = true
            end
        end
    end

    for _, task in ipairs(tasks or {}) do
        if (tonumber(task.phase) or 0) == 0 then
            local recipe = task.recipe or {}
            local recipeKey =
                tostring(
                    recipe.id
                    or recipe.module
                    or recipe.label
                    or "inconnu"
                )

            local group = grouped[recipeKey]

            if not group then
                group = {
                    id = "display-" .. recipeKey,
                    lineIndex = recipeKey,
                    recipe = recipe,
                    quantity = 0,
                    current = 0,
                    total = 0,
                    status = "waiting",
                    phase = 0,
                    hasWaiting = false,
                    hasRunning = false,
                    hasReady = false,
                    hasFailed = false
                }

                grouped[recipeKey] = group
                table.insert(ordered, group)
            end

            local quantity =
                math.max(0, tonumber(task.quantity) or 0)
            local current =
                math.max(0, tonumber(task.current) or 0)
            local total =
                math.max(1, tonumber(task.total) or quantity or 1)

            group.quantity = group.quantity + quantity
            group.total = group.total + quantity

            if task.status == "ready" then
                group.current = group.current + quantity
                group.hasReady = true
            elseif task.status == "running" then
                local ratio =
                    math.max(
                        0,
                        math.min(1, current / total)
                    )

                group.current =
                    group.current + quantity * ratio
                group.hasRunning = true
            elseif task.status == "failed" then
                group.hasFailed = true
            else
                group.hasWaiting = true
            end
        end
    end

    for _, group in ipairs(ordered) do
        if group.hasFailed or intermediateFailed then
            group.status = "failed"
        elseif group.hasReady
            and not group.hasRunning
            and not group.hasWaiting then
            group.status = "ready"
            group.current = group.quantity
        elseif group.hasRunning
            or group.hasReady
            or intermediateStarted then
            -- Même si la tâche finale n'a pas encore commencé,
            -- le produit est déjà en préparation dès qu'un ingrédient
            -- intermédiaire est en cours ou prêt.
            group.status = "running"
        else
            group.status = "waiting"
        end

        group.current =
            math.max(
                0,
                math.min(group.current, group.quantity)
            )

        group.hasWaiting = nil
        group.hasRunning = nil
        group.hasReady = nil
        group.hasFailed = nil
    end

    return ordered
end

local function runOrder()
    if #state.cart == 0 then
        return false
    end

    gui.status(
        "Commande",
        "Envoi au serveur...",
        colors.yellow,
        state.serverName or "Serveur"
    )

    local sent, sendError = network.send(
        state.serverId,
        protocol.makeMessage(
            protocol.TYPE.ORDER_CREATE,
            {
                items = state.cart
            }
        )
    )

    if not sent then
        gui.messageBox(
            "Commande impossible",
            tostring(sendError),
            false,
            "MENU"
        )
        gui.waitTouch()
        return false
    end

    local _, accepted, acceptError = waitForMessage(
        8,
        function(senderId, message)
            return senderId == state.serverId
                and (
                    message.type == protocol.TYPE.ORDER_ACCEPTED
                    or message.type == protocol.TYPE.ORDER_FAILED
                )
        end
    )

    if not accepted then
        gui.messageBox(
            "Commande impossible",
            tostring(acceptError),
            false,
            "MENU"
        )
        gui.waitTouch()
        return false
    end

    local acceptedData = accepted.data or accepted

    if accepted.type == protocol.TYPE.ORDER_FAILED then
        gui.messageBox(
            "Commande refusee",
            acceptedData.message or "Erreur serveur",
            false,
            "MENU"
        )
        gui.waitTouch()
        return false
    end

    local orderId = acceptedData.orderId
    local orderNumber =
        acceptedData.orderNumber
        or ("#" .. tostring(orderId))

    -- Le ticket reste proposé sur la Borne.
    askForTicket(orderNumber)

    -- La progression est désormais entièrement déportée sur le Moniteur.
    -- La Borne est immédiatement libérée pour le client suivant.
    state.cart = {}

    gui.messageBox(
        "Commande validee",
        "Commande "
            .. tostring(orderNumber)
            .. " transmise en cuisine.",
        true,
        "Retour au menu"
    )

    sleep(1.2)
    return true
end

local function heartbeatLoop()
    local consecutiveFailures = 0

    while true do
        sleep(3)

        if state.registered and state.serverId then
            local callWorked, sent = pcall(
                network.send,
                state.serverId,
                protocol.makeMessage(
                    protocol.TYPE.HEARTBEAT,
                    {
                        role = protocol.ROLE.TERMINAL,
                        status = "disponible"
                    }
                )
            )

            if callWorked and sent then
                consecutiveFailures = 0
            else
                consecutiveFailures = consecutiveFailures + 1
            end

            if consecutiveFailures >= 3 then
                state.registered = false
                state.serverId = nil
                state.serverName = nil
                consecutiveFailures = 0
            end
        else
            -- La Borne se réinscrit sans obliger l'utilisateur à la
            -- redémarrer ni à perdre son panier.
            local callWorked, connected =
                pcall(discoverServer)

            if not callWorked or not connected then
                state.registered = false
                sleep(2)
            end
        end
    end
end

local function browseRecipes()
    while true do
        local categoryAction = selectCategory()

        if categoryAction == "cart" then
            local cartAction = openCart()

            if cartAction == "order" then
                runOrder()
            end
        elseif categoryAction == "category" then
            local stayInCategory = true

            while stayInCategory do
                local recipeAction = selectRecipe()

                if recipeAction == "back" then
                    stayInCategory = false
                elseif recipeAction == "cart" then
                    local cartAction = openCart()

                    if cartAction == "order" then
                        runOrder()
                        stayInCategory = false
                    end
                elseif recipeAction == "recipe" then
                    local quantityAction =
                        selectQuantity()

                    if quantityAction == "cart" then
                        local cartAction = openCart()

                        if cartAction == "order" then
                            runOrder()
                            stayInCategory = false
                        end
                    end

                    -- "added" et "back" renvoient simplement
                    -- à la liste des recettes de la catégorie.
                end
            end
        end
    end
end

